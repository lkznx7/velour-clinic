<%- include('partials/header') %>

<section class="hero">
  <div class="hero-bg">
    <img src="https://images.unsplash.com/photo-1616394584738-fc6e612e71b9?w=1920&q=80" alt="Velour Clinic" class="hero-bg-img">
    <div class="hero-bg-overlay"></div>
  </div>
  <div class="container hero-content">
    <div class="hero-issue">
      <div class="hero-issue-line"></div>
      <span class="hero-tag">São Paulo</span>
      <div class="hero-issue-line"></div>
    </div>
    <h1 class="display-xl">Beleza<br>sem<br>tempo</h1>
    <p class="body-lg" style="max-width: 600px; margin-bottom: 40px; color: var(--gray-400);">
      Protocolos de excelência criados para quem entende que cuidar de si não é luxo — é necessidade.
    </p>
    <a href="/agendamento" class="btn btn-gold">Agendar Consulta</a>
  </div>
</section>

<div class="marquee-wrap">
  <div class="marquee">
    <span class="marquee-item">Hidratação Profunda</span>
    <span class="marquee-item">Laser Fracionado</span>
    <span class="marquee-item">Preenchimento Labial</span>
    <span class="marquee-item">Botox</span>
    <span class="marquee-item">Drenagem Linfática</span>
    <span class="marquee-item">Radiofrequência</span>
    <span class="marquee-item">Criolipólise</span>
    <span class="marquee-item">Fios de Sustentação</span>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="grid-3">
      <div class="service-card card">
        <span class="service-number">01</span>
        <h3 class="service-title">Facial</h3>
        <p class="service-desc">Hydra Facial, laser, microagulhamento e peeling químico para rejuvenescimento natural.</p>
        <a href="/tratamentos" class="service-link">Ver tratamentos →</a>
      </div>
      <div class="service-card card">
        <span class="service-number">02</span>
        <h3 class="service-title">Corporal</h3>
        <p class="service-desc">Drenagem linfática, radiofreqüência, criolipólise e massagem modeladora.</p>
        <a href="/tratamentos" class="service-link">Ver tratamentos →</a>
      </div>
      <div class="service-card card">
        <span class="service-number">03</span>
        <h3 class="service-title">Avançado</h3>
        <p class="service-desc">Botox, preenchimento, fios de sustentação e tratamento de estrias.</p>
        <a href="/tratamentos" class="service-link">Ver tratamentos →</a>
      </div>
    </div>
  </div>
</section>

<section class="split-section">
  <div class="split-image">
    <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=1200&q=80" alt="Excelência">
  </div>
  <div class="split-content">
    <span class="eyebrow">A Clínica</span>
    <h2 class="display-md" style="margin: 20px 0 30px;">Excelência em<br>cada detalhe</h2>
    <p class="body-md" style="margin-bottom: 20px;">
      Combinamos tecnologia de ponta com expertise especializada para criar protocolos personalizados que realçam sua beleza natural.
    </p>
    <p class="body-md" style="margin-bottom: 40px;">
      Cada tratamento é uma experiência exclusiva, desenvolvida especificamente para seu biotipo e objetivos.
    </p>
    <a href="/sobre" class="btn btn-outline">Nossa História</a>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="grid-3">
      <div class="treatment-card card">
        <img src="https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?w=800&q=80" alt="Facial" class="treatment-img">
        <div class="treatment-overlay"></div>
        <div class="treatment-content">
          <span class="caption" style="color: var(--gold);">Facial</span>
          <h3 style="font-size: 28px; margin: 8px 0;">Rejuvenescimento</h3>
          <span class="treatment-price">a partir de R$ 450</span>
        </div>
      </div>
      <div class="treatment-card card">
        <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=800&q=80" alt="Corporal" class="treatment-img">
        <div class="treatment-overlay"></div>
        <div class="treatment-content">
          <span class="caption" style="color: var(--gold);">Corporal</span>
          <h3 style="font-size: 28px; margin: 8px 0;">Modelagem</h3>
          <span class="treatment-price">a partir de R$ 380</span>
        </div>
      </div>
      <div class="treatment-card card">
        <img src="https://images.unsplash.com/photo-1519415510236-718bdfcd89c8?w=800&q=80" alt="Avançado" class="treatment-img">
        <div class="treatment-overlay"></div>
        <div class="treatment-content">
          <span class="caption" style="color: var(--gold);">Avançado</span>
          <h3 style="font-size: 28px; margin: 8px 0;">Preenchimento</h3>
          <span class="treatment-price">a partir de R$ 1.200</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section" style="background: var(--gray-800);">
  <div class="container">
    <div class="grid-4">
      <div class="stat-item">
        <span class="stat-number">3.000+</span>
        <span class="stat-label">Clientes Atendidas</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">98%</span>
        <span class="stat-label">Satisfação</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">15+</span>
        <span class="stat-label">Tratamentos</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">5+</span>
        <span class="stat-label">Anos de Experiência</span>
      </div>
    </div>
  </div>
</section>

<div class="testimonial">
  <div class="container-sm">
    <span class="testimonial-marks">"</span>
    <p class="testimonial-quote">A Velour Clinic não é apenas um espaço de beleza — é um refúgio de luxo onde cada visita se torna uma experiência transformadora.</p>
    <p class="testimonial-author">Revista Beauty Premium</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <span class="eyebrow" style="text-align: center; display: block; margin-bottom: 40px;">Galeria</span>
    <div class="gallery-grid">
      <div class="gallery-item g-span-4 g-row-4">
        <img src="https://images.unsplash.com/photo-1616394584738-fc6e612e71b9?w=800&q=80" alt="1">
      </div>
      <div class="gallery-item g-span-4 g-row-3">
        <img src="https://images.unsplash.com/photo-1560066984-138dadb4c035?w=600&q=80" alt="2">
      </div>
      <div class="gallery-item g-span-4 g-row-5">
        <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=600&q=80" alt="3">
      </div>
      <div class="gallery-item g-span-6 g-row-4">
        <img src="https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?w=800&q=80" alt="4">
      </div>
      <div class="gallery-item g-span-6 g-row-4">
        <img src="https://images.unsplash.com/photo-1519415510236-718bdfcd89c8?w=800&q=80" alt="5">
      </div>
    </div>
  </div>
</section>

<section class="section" style="text-align: center;">
  <div class="container">
    <h2 class="display-md" style="margin-bottom: 20px;">Pronta para sua<br>transformação?</h2>
    <p class="body-md" style="max-width: 500px; margin: 0 auto 40px;">
      Agende sua consulta e descubra os protocolos que tornam a Velour Clinic referência em excelência estética.
    </p>
    <a href="/agendamento" class="btn btn-gold">Agendar Consulta</a>
  </div>
</section>

